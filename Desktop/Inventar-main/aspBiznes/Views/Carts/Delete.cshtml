@model aspBiznes.Data.Cart

@{
    ViewData["Title"] = "Изтриване на поръчка";
}

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="card-title mb-2">Изтриване на поръчка</h2>
            <p class="text-muted">Сигурни ли сте, че искате да премахнете тази поръчка?</p>

            <dl class="row">
                <dt class="col-sm-3">Клиент</dt>
                <dd class="col-sm-9">@((Model.Clients != null) ? $"{Model.Clients.FirstName} {Model.Clients.LastName}" : "—")</dd>

                <dt class="col-sm-3">Продукт</dt>
                <dd class="col-sm-9">@(Model.Items?.Name ?? "—")</dd>

                <dt class="col-sm-3">Количество</dt>
                <dd class="col-sm-9">@Model.Quantity</dd>

                <dt class="col-sm-3">Дата регистрация</dt>
                <dd class="col-sm-9">@Model.DateRegister.ToString("g")</dd>
            </dl>

            <form asp-action="Delete" class="d-flex gap-2">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Откажи</a>
            </form>
        </div>
    </div>
</div>
