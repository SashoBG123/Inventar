@model IEnumerable<aspBiznes.Data.Category>

@{
    ViewData["Title"] = "Категории";
    var records = Model ?? Enumerable.Empty<aspBiznes.Data.Category>();
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-toolbar">
    <div>
        <h1>Категории</h1>
        <p>Групирайте артикулите, за да се намират по-бързо.</p>
    </div>
    @if (isAdmin)
    {
        <a class="btn btn-primary" asp-action="Create">Нова категория</a>
    }
</div>

<div class="table-card">
<div class="table-responsive">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Име</th>
            <th>Описание</th>
            <th>Дата на регистрация</th>
            @if (isAdmin)
            {
                <th class="text-end">Действия</th>
            }
        </tr>
    </thead>
    <tbody>
@if (!records.Any())
{
        <tr>
            <td colspan="@(isAdmin ? 4 : 3)" class="empty-state">Все още няма добавени категории.</td>
        </tr>
}
else
{
@foreach (var item in records) {
        <tr>
            <td class="fw-semibold">
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateRegister)
            </td>
            @if (isAdmin)
            {
                <td class="actions text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Детайли</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редакция</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Изтрий</a>
                </td>
            }
        </tr>
}
}
    </tbody>
</table>
</div>
</div>
