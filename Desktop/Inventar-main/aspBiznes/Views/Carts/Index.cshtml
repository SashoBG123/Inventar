@model IEnumerable<aspBiznes.Data.Cart>

@{
    ViewData["Title"] = "Кошници";
    var records = Model ?? Enumerable.Empty<aspBiznes.Data.Cart>();
    var isAdmin = User.IsInRole("Admin");
}

<div class="my-4">
    <div class="page-toolbar">
        <div>
            <h1>Поръчки</h1>
            <p>@(isAdmin ? "Всички клиентски заявки, продукти и количества." : "Вашите запазени поръчки.")</p>
        </div>
        <a class="btn btn-primary" asp-controller="Items" asp-action="Index">Към продуктите</a>
    </div>

    <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Клиент</th>
                            <th>Продукт</th>
                            <th>Количество</th>
                            <th>Дата регистрация</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!records.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center p-4 text-muted">Няма записи</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in records)
                            {
                                <tr>
                                    <td>@(item.Clients is not null ? $"{item.Clients.FirstName} {item.Clients.LastName}" : "—")</td>
                                    <td>@(item.Items?.Name ?? "—")</td>
                                    <td>@item.Quantity</td>
                                    <td>@(item.DateRegister.ToString("g"))</td>
                                    <td class="actions text-end">
                                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Детайли</a>
                                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редакция</a>
                                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Изтрий</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
    </div>
</div>
