@{
    ViewData["Title"] = "ИнвентарПро";
}

<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold">ИнвентарПро</h1>
                <p class="lead text-muted">Управление на артикули, категории и доставчици — бързо и лесно.</p>

                <div class="d-flex gap-2 mt-4">
                    <a class="btn btn-primary btn-lg" asp-controller="Items" asp-action="Index">Преглед на артикули</a>
                    <a class="btn btn-outline-secondary btn-lg" asp-controller="Home" asp-action="Privacy">За проекта</a>
                </div>
            </div>

            <div class="col-lg-4 d-none d-lg-block">
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center">
                        <h5 class="card-title">Бърз достъп</h5>
                        <p class="card-text text-muted mb-2">Навигирайте бързо до ключовите секции на системата.</p>
                        <a class="btn btn-sm btn-outline-primary me-1" asp-controller="Categories" asp-action="Index">Категории</a>
                        <a class="btn btn-sm btn-outline-primary me-1" asp-controller="Suppliers" asp-action="Index">Доставчици</a>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Items" asp-action="Index">Артикули</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container my-5">
    <div class="row g-4">
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Категории</h5>
                    <p class="card-text text-muted">Създавайте и редактирайте категории, за да организирате артикулите си.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Categories" asp-action="Index">Прегледай категории</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Доставчици</h5>
                    <p class="card-text text-muted">Управлявайте доставчици и контактна информация.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Suppliers" asp-action="Index">Прегледай доставчици</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Артикули</h5>
                    <p class="card-text text-muted">Добавяйте, редактирайте и следете наличности на артикули.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Items" asp-action="Index">Прегледай артикули</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">За нас</h5>
                    <p class="card-text text-muted">Информация за проекта и как да започнете да използвате системата.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-secondary w-100" asp-controller="Home" asp-action="Privacy">За проекта</a>
                    </div>
                </div>
            </div>
        </div>
    </div>  

    <div class="row mt-5">
        <div class="col-12">
            <div class="alert alert-info" role="alert">
                <strong>Съвет:</strong> Влезте за да създавате и управлявате доставчици, категории и артикули.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // design-only view: no dynamic client logic here
    </script>
}
