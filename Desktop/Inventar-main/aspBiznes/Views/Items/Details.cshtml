@model aspBiznes.Data.Item

@{
    ViewData["Title"] = Model.Name;
    var isAdmin = User.IsInRole("Admin");
    var isLoggedIn = User.Identity?.IsAuthenticated ?? false;
}

<div class="product-detail">
    <div class="detail-media">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" />
        }
        else
        {
            <div class="product-placeholder">@Model.Name?.FirstOrDefault()</div>
        }
    </div>

    <div class="detail-info">
        <a class="back-link" asp-action="Index">Назад към продуктите</a>
        <p class="section-title mb-2">@(Model.Categories?.Name ?? "Продукт")</p>
        <h1>@Model.Name</h1>
        <p class="lead">@Model.Description</p>

        <div class="detail-price">@Model.Price.ToString("0.00") лв.</div>

        <dl class="detail-list">
            <div>
                <dt>Доставчик</dt>
                <dd>@(Model.Suppliers?.Name ?? "—")</dd>
            </div>
            <div>
                <dt>Наличност</dt>
                <dd>@Model.Quantity бр.</dd>
            </div>
            <div>
                <dt>Срок</dt>
                <dd>@(Model.ExpiryDate.HasValue ? Model.ExpiryDate.Value.ToString("dd.MM.yyyy") : "—")</dd>
            </div>
        </dl>

        <div class="d-flex flex-wrap gap-2 mt-4">
            @if (isLoggedIn && !isAdmin)
            {
                <form asp-controller="Carts" asp-action="Create" method="post" class="order-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ItemId" value="@Model.Id" />
                    <input class="form-control" type="number" name="Quantity" value="1" min="1" max="@Math.Max(Model.Quantity, 1)" aria-label="Количество" />
                    <button class="btn btn-primary" type="submit" disabled="@(Model.Quantity <= 0)">Поръчай</button>
                </form>
            }
            else if (!isLoggedIn)
            {
                <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">Вход за поръчка</a>
            }

            @if (isAdmin)
            {
                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Редакция</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Изтрий</a>
            }
        </div>
    </div>
</div>
