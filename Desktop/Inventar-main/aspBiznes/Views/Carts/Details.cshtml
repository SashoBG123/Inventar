@model aspBiznes.Data.Cart

@{
    ViewData["Title"] = "Детайли на кошницата";
}

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="card-title mb-3">Детайли</h2>

            <dl class="row">
                <dt class="col-sm-3">Клиент</dt>
                <dd class="col-sm-9">@((Model.Clients != null) ? $"{Model.Clients.FirstName} {Model.Clients.LastName}" : "—")</dd>

                <dt class="col-sm-3">Продукт</dt>
                <dd class="col-sm-9">@(Model.Items?.Name ?? "—")</dd>

                <dt class="col-sm-3">Количество</dt>
                <dd class="col-sm-9">@Model.Quantity</dd>

                <dt class="col-sm-3">Дата регистрация</dt>
                <dd class="col-sm-9">@Model.DateRegister.ToString("g")</dd>
            </dl>

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-primary me-2">Редактирай</a>
                <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-outline-danger me-2">Изтрий</a>
                <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
            </div>
        </div>
    </div>
</div>
