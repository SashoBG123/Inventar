@model IEnumerable<aspBiznes.Data.Cart>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Клиент
                @* @Html.DisplayNameFor(model => model.Clients) *@
            </th>
            <th>
                Продукт
                @* @Html.DisplayNameFor(model => model.Items) *@
            </th>
            <th>
                Количество
                @* @Html.DisplayNameFor(model => model.Quantity) *@
            </th>
            <th>
                Дата регистрация
                @* @Html.DisplayNameFor(model => model.DateRegister) *@
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @* @Html.DisplayFor(modelItem => *@ @(item.Clients.FirstName + " " + item.Clients.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Items.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateRegister)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
