@{
    ViewData["Title"] = "ИнвентарПро";
}

<section class="page-hero mb-5">
    <div class="row g-0 align-items-stretch">
        <div class="col-lg-7 p-4 p-md-5">
            <p class="section-title text-white-50 mb-3">Система за управление</p>
            <h1 class="display-4 fw-bold mb-3">ИнвентарПро</h1>
            <p class="lead mb-4">Онлайн система за инвентаризация, продуктови категории, доставчици, поръчки и бързи справки за малък и среден бизнес.</p>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-light btn-lg" asp-controller="Items" asp-action="Index">Продуктов каталог</a>
                <a class="btn btn-outline-light btn-lg" asp-controller="Home" asp-action="Reports">Справки</a>
            </div>
        </div>

        <div class="col-lg-5 hero-panel d-flex align-items-center p-4 p-md-5">
            <div class="w-100">
                <div class="hero-metric mb-3">
                    <div class="h2 fw-bold mb-1">6</div>
                    <div class="text-white-50">основни модула</div>
                </div>
                <div class="hero-metric mb-3">
                    <div class="h2 fw-bold mb-1">24/7</div>
                    <div class="text-white-50">достъп до данните</div>
                </div>
                <div class="hero-metric">
                    <div class="h2 fw-bold mb-1">Admin</div>
                    <div class="text-white-50">панел за управление</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="d-flex align-items-end justify-content-between gap-3 mb-3">
        <div>
            <p class="section-title mb-1">Бърз достъп</p>
            <h2 class="h4 fw-bold mb-0">Най-важните части на системата</h2>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-md-6 col-lg-3">
            <div class="quick-card">
                <div class="card-body d-flex flex-column p-4">
                    <span class="quick-icon">К</span>
                    <h5 class="card-title">Категории</h5>
                    <p class="card-text text-muted">Създавайте и редактирайте категории, за да организирате артикулите си.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Categories" asp-action="Index">Прегледай категории</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="quick-card">
                <div class="card-body d-flex flex-column p-4">
                    <span class="quick-icon">Д</span>
                    <h5 class="card-title">Доставчици</h5>
                    <p class="card-text text-muted">Управлявайте доставчици и контактна информация.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Suppliers" asp-action="Index">Прегледай доставчици</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="quick-card">
                <div class="card-body d-flex flex-column p-4">
                    <span class="quick-icon">П</span>
                    <h5 class="card-title">Продуктов каталог</h5>
                    <p class="card-text text-muted">Артикули по категории с описание, цена, доставчик, срок и наличност.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Items" asp-action="Index">Прегледай артикули</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="quick-card">
                <div class="card-body d-flex flex-column p-4">
                    <span class="quick-icon">П</span>
                    <h5 class="card-title">Поръчки</h5>
                    <p class="card-text text-muted">Регистрираните клиенти могат да заявяват избрани стоки и количества.</p>
                    <div class="mt-auto">
                        <a class="btn btn-outline-primary w-100" asp-controller="Carts" asp-action="Index">Прегледай поръчки</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="admin-band">
        <div>
            <p class="section-title mb-1">Администраторски панел</p>
            <h2 class="h4 fw-bold mb-2">Управление без излишна сложност</h2>
            <p class="mb-0 text-muted">Екипът може да добавя, редактира и изтрива артикули, категории и доставчици, да проследява поръчките и да следи ниските наличности.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Items" asp-action="Index">Към управлението</a>
    </div>
</section>

<div class="app-note p-3 mb-4" role="alert">
    <strong>Съвет:</strong> Влезте в профила си, за да създавате и управлявате доставчици, категории и артикули.
</div>
